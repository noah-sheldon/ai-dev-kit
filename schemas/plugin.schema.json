{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PluginManifest",
  "type": "object",
  "required": ["name", "version", "description", "interface"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "interface": {
      "type": "object",
      "required": ["displayName"],
      "properties": {
        "displayName": { "type": "string" }
      }
    }
  }
}
